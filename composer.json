{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "asmit/resized-column": "^3.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "bezhansalleh/filament-language-switch": "^4.1",
        "bezhansalleh/filament-shield": "^4.1",
        "daljo25/filament-tabler-icons": "^1.0",
        "directorytree/ldaprecord": "^3.8",
        "directorytree/ldaprecord-laravel": "^3.4",
        "filament/filament": "^5.0",
        "guava/calendar": "^3.1",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.47",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.0",
        "maatwebsite/excel": "^3.1",
        "owen-it/laravel-auditing": "^14.0",
        "owenvoke/blade-fontawesome": "^3.2",
        "pusher/pusher-php-server": "^7.2",
        "tapp/filament-auditing": "^4.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "^5.0",
        "kkomelin/laravel-translatable-string-exporter": "^1.26",
        "laravel-lang/common": "^6.7",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-install-cmd": [
            "@php artisan filament:assets --ansi",
            "@fix-resized-column-selector",
            "@fix-guava-calendar-local-assets"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan filament:assets --ansi",
            "@fix-resized-column-selector",
            "@fix-guava-calendar-local-assets"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "lang-sync": [
            "@php artisan translatable:export es,eu",
            "@php artisan translatable:inspect-translations eu || true"
        ],
        "fix-resized-column-selector": [
            "sh scripts/fix-resized-column-selector.sh"
        ],
        "fix-guava-calendar-local-assets": [
            "sh scripts/fix-guava-calendar-local-assets.sh"
        ],
        "check-guava-calendar-assets": [
            "sh scripts/check-guava-calendar-assets.sh"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
